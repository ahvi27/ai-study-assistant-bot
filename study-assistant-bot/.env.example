# ============================================================================
# TELEGRAM CONFIGURATION
# ============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite (default, local development)
DATABASE_URL=sqlite:///study_bot.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/study_bot

# ============================================================================
# AI SERVICE CONFIGURATION
# ============================================================================
# AI Provider: openai or gemini
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT=30

# Google Gemini Configuration (alternative)
# GOOGLE_API_KEY=your_google_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ============================================================================
# RAG (RETRIEVAL-AUGMENTED GENERATION) CONFIGURATION
# ============================================================================
# Enable RAG for document-based Q&A
RAG_ENABLED=true
ENABLE_RAG=true

# Embeddings model for vector search
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# Vector database path
VECTOR_DB_PATH=./data/vectors

# Context settings
MAX_CONTEXT_LENGTH=4000
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# Storage type: local or s3
STORAGE_TYPE=local

# Local storage path
STORAGE_LOCAL_PATH=./data/uploads

# AWS S3 Configuration (if using S3)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=study-assistant-bucket

# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=20

# ============================================================================
# FEATURE TOGGLES
# ============================================================================
# Enable/disable specific features
ENABLE_QUIZ=true
ENABLE_FLASHCARDS=true
ENABLE_TRANSLATOR=true
ENABLE_PLANNER=true
ENABLE_REMINDERS=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/bot.log

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Debug mode (set to false in production)
DEBUG=false

# Environment: development, staging, production
ENVIRONMENT=production

# Polling interval in seconds
POLLING_INTERVAL=1

# Database type: sqlite or postgresql
DATABASE_TYPE=sqlite

# ============================================================================
# OPTIONAL: WEBHOOK CONFIGURATION (for production)
# ============================================================================
# For production, you can use webhooks instead of polling
# WEBHOOK_URL=https://yourdomain.com
# WEBHOOK_PORT=8443

# ============================================================================
# OPTIONAL: TIMEZONE
# ============================================================================
TIMEZONE=UTC

# ============================================================================
# OPTIONAL: CUSTOM SETTINGS
# ============================================================================
# Add any other environment variables your application needs here
